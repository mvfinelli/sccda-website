    },
    {
      date: new Date('2026-04-15'),
      title: 'A League Matches \u2014 Week 9',
      category: 'Weekly',
      description: 'Regular season A League matches. Check the schedule for your team\'s venue this week.',
      time: '7:00 PM',
      venue: 'Various venues',
      entryInfo: 'League Members',
