      actionLabel: 'Schedule',
    },
    {
      date: new Date('2026-05-02'),
      title: 'Spring Open Singles Championship',
      category: 'Tournament',
      description: 'Annual open singles tournament — steel tip. Open to all SCCDA members and invited guests. Format: round robin into playoffs. Cash prizes for top 3.',
      time: '11:00 AM',
      venue: "Fast Eddy's",
      entryInfo: 'Open Entry',
      recurring: '',
      actionLabel: 'Register',
    },
    {
      date: new Date('2026-05-15'),
      title: 'New Member Night',
      category: 'Social',
      description: 'Thinking about joining the league? Come meet the teams, try the boards, and get a feel for how SCCDA nights run. No experience necessary — we\'ll pair you up.',
      time: '7:00 PM',
