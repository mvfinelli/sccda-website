---
/* events.astro — Events page
   Displays events from Google Sheets (or sample data if no sheet configured).
   Filterable by category: All, Weekly, Tournaments, Social */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import EventCard from '../components/EventCard.astro';
import EventSidebar from '../components/EventSidebar.astro';

/* ---------- Google Sheets Integration ----------
   To connect your Google Sheet:
   1. Create a sheet with columns: Date, Title, Category, Description, Time, Venue, EntryInfo, Recurring, ActionLabel
   2. Publish it: File > Share > Publish to Web > CSV
   3. Set GOOGLE_SHEET_CSV_URL in your .env file
   4. Rebuild the site (Netlify will fetch fresh data)
   ------------------------------------------------ */

/* Try to fetch events from Google Sheets, fall back to sample data */
let events: any[] = [];

const sheetUrl = import.meta.env.GOOGLE_SHEET_CSV_URL;

if (sheetUrl) {
  try {
    const response = await fetch(sheetUrl);
    const csvText = await response.text();
    const rows = csvText.split('\n').slice(1); /* skip header row */

    events = rows
      .filter(row => row.trim())
      .map(row => {
        /* Parse CSV — properly handles quoted fields with commas inside them */
        const cols: string[] = [];
        let current = '';
        let inQuotes = false;
        for (let i = 0; i < row.length; i++) {
          const char = row[i];
          if (char === '"') {
            inQuotes = !inQuotes;
          } else if (char === ',' && !inQuotes) {
            cols.push(current.trim());
            current = '';
          } else {
            current += char;
          }
        }
        cols.push(current.trim()); /* push last field */
        const clean = (val: string) => val?.replace(/^"|"$/g, '').trim() || '';

        return {
          date: new Date(clean(cols[0])),
          title: clean(cols[1]),
          category: clean(cols[2]),
          description: clean(cols[3]),
          time: clean(cols[4]),
          venue: clean(cols[5]),
          entryInfo: clean(cols[6]),
          recurring: clean(cols[7]),
          actionLabel: clean(cols[8]),
        };
      })
      .filter(e => !isNaN(e.date.getTime()))
      .sort((a, b) => a.date.getTime() - b.date.getTime());
  } catch (err) {
    console.error('Failed to fetch Google Sheet:', err);
  }
}

/* If no sheet data, use sample events so the page isn't empty */
if (events.length === 0) {
