/* Group events by month for display */
const eventsByMonth = events.reduce((acc: Record<string, any[]>, event) => {
  const key = event.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }).toUpperCase();
  if (!acc[key]) acc[key] = [];
  acc[key].push(event);
  return acc;
}, {});

/* Get unique categories for filter tabs */
const categories = ['All Events', ...new Set(events.map(e => e.category))];
---

<BaseLayout title="Events" description="SCCDA Events — blind draws, tournaments, social nights, and league championships.">

  <Hero
    label="Santa Cruz County Darts Association"
    heading="Events &amp;<br/>Schedule"
    bgText="EVENTS"
  />

  <section class="events-page">
    <div class="container">

      <!-- Filter Tabs -->
      <div class="filter-tabs">
        {categories.map((cat, i) => (
          <button
            class={`filter-tab ${i === 0 ? 'active' : ''}`}
            data-category={cat === 'All Events' ? 'all' : cat.toLowerCase()}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="events-content">
        <!-- Events List (left column) -->
        <div class="events-list" id="events-list">
          {Object.entries(eventsByMonth).map(([month, monthEvents]) => (
            <div class="events-month-group">
              <div class="month-header">{month}</div>
              {(monthEvents as any[]).map(event => (
                <div data-event-category={event.category.toLowerCase()}>
                  <EventCard
                    date={event.date}
                    title={event.title}
                    category={event.category}
                    description={event.description}
                    time={event.time}
                    venue={event.venue}
                    entryInfo={event.entryInfo}
                    recurring={event.recurring}
                    actionLabel={event.actionLabel}
                  />
                </div>
              ))}
            </div>
          ))}
        </div>

        <!-- Sidebar (right column) -->
        <EventSidebar />
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  /* Client-side filtering for event categories */
  const tabs = document.querySelectorAll('.filter-tab');
  const eventCards = document.querySelectorAll('[data-event-category]');
  const monthGroups = document.querySelectorAll('.events-month-group');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      /* Update active tab */
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const category = (tab as HTMLElement).dataset.category;

      /* Show/hide events */
      eventCards.forEach(card => {
        const cardCategory = (card as HTMLElement).dataset.eventCategory;
        if (category === 'all' || cardCategory === category) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      /* Hide month headers if all their events are hidden */
      monthGroups.forEach(group => {
        const visibleCards = group.querySelectorAll('[data-event-category]:not([style*="display: none"])');
        (group as HTMLElement).style.display = visibleCards.length > 0 ? '' : 'none';
      });
    });
  });
</script>
