---
/* standings.astro — Division Standings
   Embeds Dart Connect standings via iframe */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Standings" description="SCCDA Division Standings — A League and B League rankings updated live.">

  <Hero
    label="Spring 2026"
    heading="Division<br/>Standings"
    bgText="STANDINGS"
  />

  <section class="iframe-section">
    <div class="container">
      <div class="iframe-wrapper">
        <iframe
          src="https://tv.dartconnect.com/league/SaCzDA/21880/standings"
          title="SCCDA Division Standings"
          style="min-height: 800px;"
          loading="lazy"
        ></iframe>
      </div>
      <p class="iframe-fallback">
        Can't see the standings? <a href="https://tv.dartconnect.com/league/SaCzDA/21880/standings" target="_blank" rel="noopener">View on Dart Connect</a>
      </p>
    </div>
  </section>

</BaseLayout>
