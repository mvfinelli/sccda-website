# Google Sheets CSV URL for events data
# To set this up:
# 1. Create a Google Sheet with columns: Date, Title, Category, Description, Time, Venue, EntryInfo, Recurring, ActionLabel
# 2. Go to File > Share > Publish to Web
# 3. Select the sheet tab and "CSV" format
# 4. Copy the published URL and paste it below

GOOGLE_SHEET_CSV_URL=
